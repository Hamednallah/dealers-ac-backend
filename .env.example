# ─── Database ────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/dealersac
DB_USER=dealersac
DB_PASSWORD=dealersac_secret
DB_NAME=dealersac

# ─── JWT (minimum 256-bit / 32 characters) ───────────────
JWT_SECRET=change-me-to-a-very-long-random-secret-256-bits-minimum
JWT_EXPIRATION_MS=900000

# ─── Admin Seed ──────────────────────────────────────────
ADMIN_PASSWORD=Admin@1234!

# ─── Mailgun ─────────────────────────────────────────────
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM=noreply@yourdomain.com

# ─── Webhooks ────────────────────────────────────────────
WEBHOOK_URL=https://your-webhook-receiver.com/events

# ─── Twilio (stub — configure when ready) ────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1234567890
